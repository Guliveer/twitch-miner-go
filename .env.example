# Global
LOG_LEVEL=DEBUG
PORT=9090
# Optional GHCR image override for Docker Compose
# TWITCH_MINER_IMAGE=ghcr.io/guliveer/twitch-miner-go:latest

# Twitch runtime identifiers (optional — built-in defaults are used if unset)
# Override recommended: defaults may become stale as Twitch updates their clients.
# Get these from: https://github.com/Guliveer/twitch-miner-go#twitch-client-identifiers
# TWITCH_CLIENT_ID_TV=
# TWITCH_CLIENT_ID_BROWSER=
# TWITCH_CLIENT_VERSION=

# Optional Twitch client identifiers for future compatibility
# TWITCH_CLIENT_ID_MOBILE=
# TWITCH_CLIENT_ID_ANDROID=
# TWITCH_CLIENT_ID_IOS=

# Dashboard authentication (optional — HTTP Basic Auth)
# Generate the password hash with: ./scripts/gen-dashboard-auth.sh
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD_SHA256=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8

# Global notification secrets (shared by all accounts unless overridden per-account)
TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=987654321
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Per-account overrides (take precedence over global)
# TELEGRAM_CHAT_ID_GULIVEER_=111222333
# DISCORD_WEBHOOK_GULIVEER_=https://discord.com/api/webhooks/...

# Auth token (recommended for headless environments)
# TWITCH_AUTH_TOKEN_GULIVEER_=your_oauth_token

# Password (last resort — may require 2FA)
# TWITCH_PASSWORD_GULIVEER_=your_twitch_password
